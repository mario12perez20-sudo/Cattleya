# Credenciales de Hostinger para CATTLEYA — independientes de Beer Garden.
# Cópialo como .env (que ya está en .gitignore) y completa los valores
# desde hPanel → Sitios web → Cattleya → Archivos → Detalles de FTP.

FTP_HOST=ftp.tu-dominio-cattleya.com
FTP_USER=usuario_ftp_cattleya
FTP_PASSWORD=clave_ftp_cattleya
FTP_REMOTE_DIR=/public_html
FTP_SECURE=false
